/* =========================================================
   LLM Manager -- Terminal Green/Black Theme
   ========================================================= */

/* ---- Color palette ---- */
$accent:          #00ff41;
$surface:         #0a1a0a;
$surface-darken-1:#060e06;
$background:      #000000;
$text:            #00cc33;
$text-muted:      #007722;
$success:         #00ff41;
$warning:         #ffff00;
$error:           #ff2222;
$primary:         #00dd33;
$primary-darken-2:#003311;
$primary-darken-3:#001a08;

/* ---- Root ---- */
Screen {
    background: $background;
    color: $text;
}

/* ---- Tabs ---- */
TabbedContent {
    height: 1fr;
}

TabPane {
    padding: 1 2;
}

/* ---- Section headings ---- */
.section-heading {
    color: $accent;
    text-style: bold;
    padding: 0 0 0 0;
    margin: 1 0 1 0;
    border-bottom: ascii $primary-darken-2;
    width: 100%;
}

/* ---- Form elements ---- */
.form-label {
    color: $text-muted;
    margin-top: 1;
    margin-bottom: 0;
}

.form-hint {
    color: $text-muted;
    text-style: italic;
}

Input {
    background: $surface;
    border: tall $primary-darken-2;
    color: $text;
}

Input:focus {
    border: tall $accent;
}

Select {
    background: $surface;
    color: $text;
}

/* ---- Buttons ---- */
Button {
    margin: 0 1 0 0;
}

Button.success {
    color: $success;
}

/* ---- Status bar ---- */
.status-bar {
    background: $surface;
    color: $text-muted;
    height: 1;
    padding: 0 1;
}

/* ---- Toolbar ---- */
#logs-toolbar {
    height: 3;
    background: $surface;
    align: left middle;
    padding: 0 1;
}

.toolbar-label {
    color: $text-muted;
    margin-right: 1;
}

/* ---- Dashboard ---- */
#server-cards-row {
    height: auto;
    margin-bottom: 1;
}

#gpu-meters-container {
    height: auto;
    max-height: 20;
}

#system-meters {
    height: auto;
    padding: 0 1;
}

/* ---- Server card ---- */
ServerCard {
    height: auto;
    border: ascii $primary-darken-2;
    padding: 1 2;
    margin: 0 1 1 0;
    min-width: 26;
    background: $surface;
}

/* ---- Server management ---- */
#server-list-panel {
    width: 22;
    border-right: ascii $primary-darken-2;
    padding: 0 1;
    background: $surface;
}

#flag-form-panel {
    width: 1fr;
    padding: 0 1;
}

/* ---- Benchmark ---- */
#run-form {
    height: 1fr;
    padding: 0 1;
    overflow-y: auto;
}

#run-controls {
    height: auto;
    margin-top: 1;
}

/* ---- Wizard ---- */
#wizard-layout {
    height: 1fr;
}

#wizard-left {
    width: 36;
    border-right: ascii $primary-darken-2;
    padding: 0 1;
}

#wizard-right {
    width: 1fr;
    padding: 0 1;
}

/* ---- Profile panel ---- */
#profile-list-panel {
    width: 1fr;
    border-right: ascii $primary-darken-2;
    background: $surface;
    padding: 0 1;
}

#profile-detail-panel {
    width: 1fr;
    padding: 0 1;
}

/* ---- DataTable ---- */
DataTable {
    height: 1fr;
    border: ascii $primary-darken-2;
}

/* ---- Log view ---- */
LogView {
    border: ascii $primary-darken-2;
    background: $surface-darken-1;
}

/* ---- Footer ---- */
Footer {
    background: $surface;
    color: $text-muted;
}

/* ---- Header ---- */
Header {
    background: $surface;
    color: $accent;
    text-style: bold;
}

/* ---- Dialogs ---- */
ConfirmDialog > Vertical {
    border: ascii $accent;
}

/* ---- ListView ---- */
ListView {
    background: $surface;
    border: ascii $primary-darken-2;
}

ListItem {
    background: $surface;
    color: $text;
}

ListItem:hover {
    background: $primary-darken-2;
}

/* ---- OptionList (Select dropdown) ---- */
OptionList {
    background: $surface;
    border: ascii $accent;
    color: $text;
}
