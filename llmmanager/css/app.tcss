/* =========================================================
   LLM Manager — Global Stylesheet
   ========================================================= */

/* ---- Color palette ---- */
$accent:          #7c6af7;
$surface:         #1e1e2e;
$surface-darken-1:#181825;
$background:      #11111b;
$text:            #cdd6f4;
$text-muted:      #6c7086;
$success:         #a6e3a1;
$warning:         #f9e2af;
$error:           #f38ba8;
$primary:         #89b4fa;
$primary-darken-2:#45475a;
$primary-darken-3:#313244;

/* ---- Root ---- */
Screen {
    background: $background;
    color: $text;
}

/* ---- Tabs ---- */
TabbedContent {
    height: 1fr;
}

TabPane {
    padding: 1 2;
}

/* ---- Section headings ---- */
.section-heading {
    color: $accent;
    text-style: bold;
    padding: 0 0 0 0;
    margin: 1 0 1 0;
    border-bottom: solid $primary-darken-2;
    width: 100%;
}

/* ---- Form elements ---- */
.form-label {
    color: $text-muted;
    margin-top: 1;
    margin-bottom: 0;
}

.form-hint {
    color: $text-muted;
    text-style: italic;
}

Input {
    background: $surface;
    border: tall $primary-darken-2;
}

Input:focus {
    border: tall $accent;
}

Select {
    background: $surface;
}

/* ---- Buttons ---- */
Button {
    margin: 0 1 0 0;
}

/* ---- Status bar ---- */
.status-bar {
    background: $surface;
    color: $text-muted;
    height: 1;
    padding: 0 1;
}

/* ---- Toolbar ---- */
#logs-toolbar {
    height: 3;
    background: $surface;
    align: left middle;
    padding: 0 1;
}

.toolbar-label {
    color: $text-muted;
    margin-right: 1;
}

/* ---- Dashboard ---- */
#server-cards-row {
    height: auto;
    margin-bottom: 1;
}

#gpu-meters-container {
    height: auto;
    max-height: 20;
}

#system-meters {
    height: auto;
    padding: 0 1;
}

/* ---- Server card ---- */
ServerCard {
    height: auto;
    border: round $primary-darken-2;
    padding: 1 2;
    margin: 0 1 1 0;
    min-width: 26;
    background: $surface;
}

/* ---- Server management ---- */
#server-list-panel {
    width: 22;
    border-right: solid $primary-darken-2;
    padding: 0 1;
    background: $surface;
}

#flag-form-panel {
    width: 1fr;
    padding: 0 1;
}

/* ---- Benchmark ---- */
#run-form {
    height: 1fr;
    padding: 0 1;
    overflow-y: auto;
}

#run-controls {
    height: auto;
    margin-top: 1;
}

/* ---- Wizard ---- */
#wizard-layout {
    height: 1fr;
}

#wizard-left {
    width: 36;
    border-right: solid $primary-darken-2;
    padding: 0 1;
}

#wizard-right {
    width: 1fr;
    padding: 0 1;
}

/* ---- Profile panel ---- */
#profile-list-panel {
    width: 1fr;
    border-right: solid $primary-darken-2;
    background: $surface;
    padding: 0 1;
}

#profile-detail-panel {
    width: 1fr;
    padding: 0 1;
}

/* ---- DataTable ---- */
DataTable {
    height: 1fr;
    border: solid $primary-darken-2;
}

/* ---- Log view ---- */
LogView {
    border: solid $primary-darken-2;
    background: $surface-darken-1;
}

/* ---- Footer ---- */
Footer {
    background: $surface;
    color: $text-muted;
}

/* ---- Header ---- */
Header {
    background: $surface;
    color: $primary;
    text-style: bold;
}
